{
  "extends": [
    "@phanect/configs/ts/nodejs",
    "@phanect/configs/ts/addons/npm"
  ],
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.mjs",
    "**/*.jsx"
  ],
  "exclude": [
    "dist",
    "node_modules",
    // Use different tsconfig.json for universal code
    "./src/universal/**"
  ]
